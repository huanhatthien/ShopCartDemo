@model ShopCart.Models.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container mt-4 text-center">
    <div class="py-4">
        <div style="font-size:72px">🎉</div>
        <h2 class="text-success">Đặt hàng thành công!</h2>
        <p class="text-muted">
            Cảm ơn <strong>@Model.CustomerName</strong>!
        </p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6 text-start">

            <div class="card mb-3">
                <div class="card-header bg-dark text-white">
                    📄 Đơn hàng #@Model.Id
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-4">Trạng thái</dt>
                        <dd class="col-8">
                            <span class="badge bg-success">@Model.Status</span>
                        </dd>
                        <dt class="col-4">Ngày đặt</dt>
                        <dd class="col-8">
                            @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                        </dd>
                        <dt class="col-4">Giao đến</dt>
                        <dd class="col-8">@Model.Address</dd>
                    </dl>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">📦 Chi tiết đơn hàng</div>
                <div class="card-body p-0">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th style="width:60px">SL</th>
                                <th style="width:120px">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.OrderDetails)
                            {
                                <tr>
                                    <td>
                                        <strong>@d.ProductName</strong>

                                        @if (!string.IsNullOrEmpty(d.SelectedSize))
                                        {
                                            <span class="badge bg-secondary ms-2">Size: @d.SelectedSize</span>
                                        }
                                    </td>
                                    <td>@d.Quantity</td>
                                    <td>@d.SubTotal.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-dark">
                                <td colspan="2" class="fw-bold">Tổng tiền</td>
                                <td class="fw-bold">
                                    @Model.TotalAmount.ToString("N0") đ
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <a asp-controller="Product" asp-action="Index"
               class="btn btn-primary w-100 py-2 fs-5">
                🛍️ Tiếp tục mua sắm
            </a>
        </div>
    </div>
</div>