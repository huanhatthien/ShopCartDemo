@{
    ViewData["Title"] = "Thanh toán";
    var cart = (ShopCart.Models.ShoppingCart)ViewBag.Cart;
}

<div class="container mt-4">
    <h2 class="mb-4">📋 Thông tin đặt hàng</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        <div class="col-md-7">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5>📍 Thông tin giao hàng</h5>
                    <form asp-action="Checkout" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Họ và tên *</label>
                                <input name="customerName" type="text"
                                       class="form-control" required
                                       placeholder="Nguyễn Văn A" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Điện thoại</label>
                                <input name="phone" type="tel"
                                       class="form-control"
                                       placeholder="09xx xxx xxx" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Địa chỉ *</label>
                                <input name="address" type="text"
                                       class="form-control" required
                                       placeholder="123 Lý Thường Kiệt, TP.HCM" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Ghi chú</label>
                                <textarea name="note" class="form-control"
                                          rows="2"></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit"
                                        class="btn btn-danger btn-lg w-100">
                                    🎉 Đặt hàng ngay
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>🧾 Tóm tắt đơn</h5>
                    @foreach (var item in cart.Items)
                    {
                        <div class="d-flex justify-content-between py-2 border-bottom align-items-center">
                            <div>
                                <strong>@item.ProductName</strong> × @item.Quantity

                                @if (!string.IsNullOrEmpty(item.SelectedSize))
                                {
                                    <br />
                                    <span class="badge bg-secondary mt-1">Size: @item.SelectedSize</span>
                                }
                            </div>
                            <span class="fw-semibold">
                                @((item.Price * item.Quantity).ToString("N0")) đ
                            </span>
                        </div>
                    }
                    <div class="d-flex justify-content-between mt-3 fw-bold fs-5 text-danger">
                        <span>Tổng cộng</span>
                        <span>@cart.TotalPrice.ToString("N0") đ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>