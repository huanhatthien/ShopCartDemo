@model IEnumerable<ShopCart.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";
}

<div class="container mt-4">
    <h2 class="mb-4">🛍️ Danh sách sản phẩm</h2>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <div style="font-size:60px;line-height:1.1">
                            @p.Emoji
                        </div>
                        <h5 class="mt-2 mb-1">@p.Name</h5>
                        <span class="badge bg-secondary mb-1">
                            @p.Category
                        </span>
                        <p class="text-muted small">@p.Description</p>
                        <p class="fs-5 fw-bold text-danger">
                            @if (p.Name == "My Heart")
                            {
                                <span>Vô giá ❤️</span>
                            }
                            else
                            {
                                <span>@p.Price.ToString("N0") đ</span>
                            }
                        </p>
                    </div>
                    <div class="card-footer bg-white border-0 pb-3">
                        <form asp-controller="Cart" asp-action="AddToCart" method="post">
                            <input type="hidden" name="id" value="@p.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />

                            <div class="input-group">
                                @if (!string.IsNullOrEmpty(p.Name) && p.Name.ToLower().Contains("áo"))
                                {
                                    <select name="selectedSize" class="form-select" style="max-width:80px">
                                        <option value="S">S</option>
                                        <option value="M" selected>M</option>
                                        <option value="L">L</option>
                                        <option value="XL">XL</option>
                                    </select>
                                }
                                else if (!string.IsNullOrEmpty(p.Name) && p.Name.ToLower().Contains("giày"))
                                {
                                    <select name="selectedSize" class="form-select" style="max-width:80px">
                                        @for (int i = 30; i <= 40; i++)
                                        {
                                            if (i == 39)
                                            {
                                                <option value="@i" selected>@i</option>
                                            }
                                            else
                                            {
                                                <option value="@i">@i</option>
                                            }
                                        }
                                    </select>
                                }
                                else
                                {
                                    <input type="hidden" name="selectedSize" value="" />
                                }

                                @if (p.Name == "My Heart")
                                {
                                    <input type="number" name="quantity"
                                           value="1" min="1" max="99"
                                           class="form-control"
                                           style="max-width:72px; background-color:#f8d7da; color:#721c24;"
                                           oninput="if(this.value > 1) { this.value = 1; this.setCustomValidity('Trái tim anh chỉ có 1 ❤️'); this.reportValidity(); setTimeout(() => this.setCustomValidity(''), 2000); }" />
                                }
                                else
                                {
                                    <input type="number" name="quantity"
                                           value="1" min="1" max="99"
                                           class="form-control"
                                           style="max-width:72px" />
                                }

                                <button type="submit" class="btn btn-primary">
                                    Thêm
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>